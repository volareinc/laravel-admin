{
    "name": "volareinc/laravel-admin",
    "description": "laravel admin (fork of https://github.com/z-song/laravel-admin)",
    "type": "library",
    "keywords": ["laravel", "admin", "grid", "form"],
    "homepage": "https://github.com/volareinc/laravel-admin",
    "license": "MIT",
    "authors": [
        {
            "name": "volareinc",
            "homepage": "https://github.com/volareinc"
        },
        {
            "name": "zsong",
            "email": "zosong@126.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/dom-crawler": "^6.4|^7.0",
        "laravel/framework": "^11.0|^12.0",
        "doctrine/dbal": "^3.6|^4.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "intervention/image": "^2.7|^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Encore\\Admin\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Models\\": "tests/models",
            "Tests\\Controllers\\": "tests/controllers"
        },
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "scripts": {
        "test": "./vendor/bin/phpunit"
    },
    "suggest": {
        "intervention/image": "Required to handling and manipulation upload images (^2.7|^3.0).",
        "spatie/eloquent-sortable": "Required to built orderable grid."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Encore\\Admin\\AdminServiceProvider"
            ],
            "aliases": {
                "Admin": "Encore\\Admin\\Facades\\Admin"
            }
        }
    }
}
